VITE_SUPABASE_URL=https://zpfscoqzzbmdidrozpyv.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Note: Admin/cashier operations now use Supabase Edge Functions.
